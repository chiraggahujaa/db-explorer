# Server Configuration
PORT=5000
NODE_ENV=production
API_BASE_URL=https://your-api.vercel.app

# Database Configuration (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Database password - required for pg-boss job queue (optional on Vercel)
# Get this from: Supabase Dashboard > Project Settings > Database > Database password
DB_PASSWORD=your_database_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# CORS Configuration
# Add your frontend Vercel URL here
FRONTEND_URL=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-preview.vercel.app

# Maintenance Mode
MAINTENANCE_MODE=false

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Test Configuration (Optional)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test_password